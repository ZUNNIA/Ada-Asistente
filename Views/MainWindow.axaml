<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AsistenteVirtual.ViewModels"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:const="using:AsistenteVirtual.Constants" 
        xmlns:views="using:AsistenteVirtual.Views"
        x:Class="AsistenteVirtual.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="avares://Ada/Resources/Icons/ada.png"
        Title="Ada Asistente"
        Width="1100" 
        Height="800"
        WindowStartupLocation="CenterScreen"
        Background="Transparent">

    <!-- 
        CONTENEDOR RAÍZ 
        Organizado en una rejilla de 3 columnas: Historial, Chat y Archivos.
    -->
    <Grid Name="MainGrid">
        <Grid.Background>
            <SolidColorBrush Color="{StaticResource BaseBgSurface}"/>
        </Grid.Background>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
        </Grid.ColumnDefinitions>

        <!-- ================================================================== -->
        <!-- REGIÓN: NOTIFICACIONES (CAPA SUPERIOR Z-INDEX 1100)                -->
        <!-- ================================================================== -->
        <ItemsControl Grid.Column="0" 
                    ItemsSource="{Binding ErrorNotifications}"
                    VerticalAlignment="Top" 
                    HorizontalAlignment="Left"
                    Margin="10,10,0,0" 
                    ZIndex="1100">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="vm:ErrorNotificationViewModel">
                    <Border Name="NotificationItemRoot"
                            Width="230"
                            Background="{Binding IsCritical, Converter={StaticResource BooleanToErrorBackgroundConverter}}"
                            BorderBrush="{Binding IsCritical, Converter={StaticResource BooleanToErrorBorderConverter}}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10"
                            Margin="0,5">

                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                        
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                            <TextBlock Grid.Column="0" Grid.Row="0"
                                        Text="{Binding Message}" 
                                        TextWrapping="Wrap" 
                                        VerticalAlignment="Center" 
                                        Foreground="White"
                                        FontSize="13"/>
                            
                            <Button Grid.Column="1" Grid.Row="0"
                                    Classes="imageButton"
                                    Command="{Binding CloseCommand}"
                                    CommandParameter="{Binding}"
                                    VerticalAlignment="Top"
                                    Height="24" Width="24">
                                <Image Width="12" Height="12">
                                    <Image.Source>
                                        <svg:SvgImage Source="avares://Ada/Resources/Icons/delete.svg" Css="* { fill: white; }"/>
                                    </Image.Source>
                                </Image>
                            </Button>
                            
                            <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                        Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        Spacing="10"
                                        Margin="0,10,0,0">
                                
                                <Button Content="Copiar Detalles"
                                        Classes="linkButton"
                                        Foreground="White"
                                        Command="{Binding CopyDetailsCommand}"
                                        IsVisible="{Binding CanCopyDetails}"/>

                                <Button Content="{Binding PrimaryActionText}"
                                        Classes="linkButton"
                                        Foreground="White"
                                        Command="{Binding PrimaryActionCommand}"
                                        IsVisible="{Binding PrimaryActionText, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- ================================================================== -->
        <!-- REGIÓN: PANELES LATERALES Y ÁREAS DE ACTIVACIÓN                    -->
        <!-- ================================================================== -->

        <!-- Panel Izquierdo: Historial -->
        <views:HistoryPanel Name="HistoryPanelControl" 
                            Grid.Column="0"
                            ZIndex="10"
                            PointerEntered="HistoryPanel_PointerEntered"
                            PointerExited="HistoryPanel_PointerExited">
            <views:HistoryPanel.RenderTransform>
                <TranslateTransform X="-250"/>
            </views:HistoryPanel.RenderTransform>
        </views:HistoryPanel>
            
        <Panel Name="HistoryTriggerArea" 
                Grid.Column="0" 
                Width="30" 
                HorizontalAlignment="Left" 
                Background="Transparent" 
                ZIndex="5"
                PointerEntered="HistoryTriggerArea_PointerEntered"
                PointerExited="HistoryTriggerArea_PointerExited" />

        <!-- Panel Derecho: Archivos -->
        <views:FilesPanel Name="FilesPanelControl" 
                        Grid.Column="2"
                        ZIndex="10"
                        PointerEntered="FilesPanel_PointerEntered"
                        PointerExited="FilesPanel_PointerExited">
            <views:FilesPanel.RenderTransform>
                <TranslateTransform X="250"/>
            </views:FilesPanel.RenderTransform>
        </views:FilesPanel>

        <Panel Name="FilesTriggerArea" 
                Grid.Column="2" 
                Width="30" 
                HorizontalAlignment="Right" 
                Background="Transparent" 
                ZIndex="5"
                PointerEntered="FilesTriggerArea_PointerEntered"
                PointerExited="FilesTriggerArea_PointerExited" />

        <!-- ================================================================== -->
        <!-- REGIÓN: MODALES Y OVERLAYS (Z-INDEX 100+)                          -->
        <!-- ================================================================== -->

        <!-- Menú Flotante de Usuario (Flyout) -->
        <Grid Grid.ColumnSpan="3" ZIndex="99" Background="Transparent" IsVisible="{Binding UI.IsSettingsFlyoutOpen}" PointerPressed="Overlay_PointerPressed">
            <Border Name="SettingsFlyoutContent"
                    Background="{StaticResource BgSurfaceBrush}" 
                    BorderBrush="{StaticResource BorderBrush}" 
                    BorderThickness="1"
                    CornerRadius="15" Padding="5" Margin="10,0,0,60" 
                    HorizontalAlignment="Left" VerticalAlignment="Bottom" Width="230"
                    PointerPressed="Content_PointerPressed">
                <StackPanel Spacing="5">
                    <Button Classes="sidePanelButton" Command="{Binding OpenSubscriptionsWindowCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Image Width="18" Height="18"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/ada.svg"/></Image.Source></Image>
                            <TextBlock Text="{DynamicResource Nav_Credits}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="sidePanelButton" Command="{Binding OpenSettingsWindowCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Image Width="18" Height="18"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/settings.svg"/></Image.Source></Image>
                            <TextBlock Text="{DynamicResource Nav_Settings}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="sidePanelButton" Command="{Binding LogoutCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Image Width="18" Height="18"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/auth_logout.svg"/></Image.Source></Image>
                            <TextBlock Text="{DynamicResource Nav_Logout}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tienda de Suscripciones -->
        <views:StoreView Grid.ColumnSpan="3" ZIndex="1001" PointerPressed="Overlay_PointerPressed"/>

        <!-- Ventana de Configuración -->
        <Grid Grid.ColumnSpan="3" Background="#AA000000" ZIndex="1000" IsVisible="{Binding UI.IsSettingsWindowOpen}" PointerPressed="Overlay_PointerPressed">
            <Border Classes="overlayBorder" Width="500" MinHeight="400" PointerPressed="Content_PointerPressed">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                        <TextBlock Text="{DynamicResource Nav_Settings}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Border Classes="toggleSwitchContainer" HorizontalAlignment="Center">
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="{Binding SelectedSettingsTab, Converter={StaticResource SettingsTabToIndexConverter}}" Classes="toggleSwitchSlider"/>
                                <Button Grid.Column="0" Content="{DynamicResource Settings_Tab_General}" Classes="toggleSwitchButton" Command="{Binding SelectSettingsTabCommand}" CommandParameter="{x:Static const:TabNames.SettingsGeneral}"/>
                                <Button Grid.Column="1" Content="{DynamicResource Settings_Tab_About}" Classes="toggleSwitchButton" Command="{Binding SelectSettingsTabCommand}" CommandParameter="{x:Static const:TabNames.SettingsAbout}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <!-- Contenido General -->
                    <StackPanel Grid.Row="1" Margin="25" Spacing="20" IsVisible="{Binding IsGeneralTabActive}">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Text="{DynamicResource Settings_Lbl_Language}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Classes="accentButton" Command="{Binding ToggleLanguageCommand}" Width="140">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Image Width="16" Height="16"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/settings.svg"/></Image.Source></Image>
                                    <TextBlock Text="{Binding CurrentLanguageLabel}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <StackPanel Spacing="10">
                            <TextBlock Text="{DynamicResource Settings_Lbl_Memories}" FontWeight="Bold" FontSize="16"/>
                            <Button Content="{DynamicResource Settings_Btn_ManageMemories}" Classes="linkButton" Command="{Binding OpenMemoriesWindowCommand}"/>
                        </StackPanel>
                    </StackPanel>
                    <!-- Contenido Acerca de -->
                    <StackPanel Grid.Row="1" Margin="25" Spacing="15" IsVisible="{Binding IsAboutTabActive}">
                        <Button Content="{DynamicResource Settings_Btn_History}" Classes="linkButton" Command="{Binding OpenUpdateHistoryWindowCommand}"/>
                        <Button Content="{DynamicResource Settings_Btn_Privacy}" Classes="linkButton" Command="{Binding OpenLegalWindowCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Gestor de Memorias -->
        <Grid Grid.ColumnSpan="3" ZIndex="1001" IsVisible="{Binding UI.IsMemoriesWindowOpen}">
            <Border Background="#AA000000" PointerPressed="Overlay_PointerPressed"/>
            <Border Classes="overlayBorder" Width="650" MinHeight="550" PointerPressed="Content_PointerPressed">
                <Grid RowDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Row="0" Margin="20" Spacing="5">
                        <TextBlock Text="{DynamicResource Memories_Title}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Memories_Subtitle}" TextWrapping="Wrap" TextAlignment="Center" Foreground="{StaticResource TextDimBrush}"/>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="20,0">
                        <ItemsControl ItemsSource="{Binding Memories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:MemoryViewModel">
                                    <Border Padding="12" Margin="0,4" CornerRadius="10" BorderThickness="1" BorderBrush="#22FFFFFF" Background="#0AFFFFFF">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Content}" VerticalAlignment="Center" TextWrapping="Wrap" IsVisible="{Binding IsDisplaying}"/>
                                            <TextBox Grid.Column="0" Text="{Binding Content, Mode=TwoWay}" IsVisible="{Binding IsEditing}" Classes="inputEditor" Padding="0"/>
                                            <Button Grid.Column="1" Command="{Binding EditCommand}" IsVisible="{Binding IsDisplaying}" Classes="imageButton historyActionButton" Margin="10,0,0,0">
                                                <Image Width="14" Height="14"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/edit.svg"/></Image.Source></Image>
                                            </Button>
                                            <Button Grid.Column="2" Command="{Binding DeleteCommand}" Classes="imageButton historyActionButton" Margin="5,0,0,0">
                                                <Image Width="14" Height="14"><Image.Source><svg:SvgImage Source="avares://Ada/Resources/Icons/delete.svg"/></Image.Source></Image>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="20">
                        <Border Grid.Column="0" Classes="inputBorder" BorderBrush="{StaticResource BorderBrush}">
                            <TextBox Watermark="{DynamicResource Memories_Placeholder}" Text="{Binding NewMemoryContent, Mode=TwoWay}" Classes="inputEditor"/>
                        </Border>
                        <Button Grid.Column="1" Content="{DynamicResource Memories_Btn_Save}" Command="{Binding AddMemoryCommand}" Classes="accentButton" Margin="10,0,0,0" Padding="25,10"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Ventanas de Texto (Historial y Legal) -->
        <!-- Historial de Versiones -->
        <Grid Grid.ColumnSpan="3" Background="#AA000000" ZIndex="1002" IsVisible="{Binding UI.IsUpdateHistoryWindowOpen}" PointerPressed="Overlay_PointerPressed">
            <Border Classes="overlayBorder" Width="700" MinHeight="600" PointerPressed="Content_PointerPressed">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                        <TextBlock Text="{DynamicResource Update_Title}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Border Classes="toggleSwitchContainer" HorizontalAlignment="Center">
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="{Binding SelectedUpdateHistoryTab, Converter={StaticResource UpdateHistoryTabToIndexConverter}}" Classes="toggleSwitchSlider"/>
                                <Button Grid.Column="0" Content="{DynamicResource Update_Tab_App}" Classes="toggleSwitchButton" Command="{Binding SelectUpdateHistoryTabCommand}" CommandParameter="{x:Static const:TabNames.UpdateHistoryApp}"/>
                                <Button Grid.Column="1" Content="{DynamicResource Update_Tab_Server}" Classes="toggleSwitchButton" Command="{Binding SelectUpdateHistoryTabCommand}" CommandParameter="{x:Static const:TabNames.UpdateHistoryServer}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="25">
                        <views:MarkdownView Markdown="{Binding CurrentChangelogContent}"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Documentación Legal -->
        <Grid Grid.ColumnSpan="3" Background="#AA000000" ZIndex="1003" IsVisible="{Binding UI.IsLegalWindowOpen}" PointerPressed="Overlay_PointerPressed">
            <Border Classes="overlayBorder" Width="700" MinHeight="600" PointerPressed="Content_PointerPressed">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Margin="20" Spacing="15">
                        <TextBlock Text="{DynamicResource Legal_Title}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <Border Classes="toggleSwitchContainer" HorizontalAlignment="Center">
                            <Grid ColumnDefinitions="*,*">
                                <Border Grid.Column="{Binding SelectedLegalTab, Converter={StaticResource LegalTabToIndexConverter}}" Classes="toggleSwitchSlider"/>
                                <Button Grid.Column="0" Content="{DynamicResource Legal_Tab_Privacy}" Classes="toggleSwitchButton" Command="{Binding SelectLegalTabCommand}" CommandParameter="{x:Static const:TabNames.LegalPrivacy}"/>
                                <Button Grid.Column="1" Content="{DynamicResource Legal_Tab_Terms}" Classes="toggleSwitchButton" Command="{Binding SelectLegalTabCommand}" CommandParameter="{x:Static const:TabNames.LegalTerms}"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" Margin="25">
                        <views:MarkdownView Markdown="{Binding CurrentLegalContent}"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ================================================================== -->
        <!-- REGIÓN: ÁREA CENTRAL DE CHAT                                       -->
        <!-- ================================================================== -->
        <views:ChatArea Name="ChatAreaControl" Grid.Column="1"/>

        <!-- Indicador de Drag & Drop -->
        <Border Name="DropZoneVisualIndicator" Grid.Column="1" Background="#400078D7" BorderBrush="#FF0078D7" BorderThickness="2" CornerRadius="15" Margin="10" IsVisible="False" IsHitTestVisible="False">
            <TextBlock Text="{DynamicResource DropZone_Text}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>

        <!-- Capa de Autenticación -->
        <views:AuthView Grid.ColumnSpan="3" ZIndex="500"/>

        <!-- Overlay de Imagen Fullscreen -->
        <Grid Grid.ColumnSpan="3" ZIndex="2000" IsVisible="{Binding UI.IsImageFullscreenOpen}">
            <Border Background="#F2000000" PointerPressed="Overlay_PointerPressed">
                <Image Source="{Binding UI.FullscreenImage}" Stretch="Uniform" Margin="50"/>
            </Border>
        </Grid>
    </Grid>
</Window>