{
    "version": "0.2",
    "language": "en,es",
    // Palabras específicas de ESTE proyecto
    "words": [
        "MiProducto",
        "MiServicio",
        "endpoint",
        "DTOs",
        "viewmodel",
        "OnInit"
    ],
    // Carpetas que no quieres revisar (muy útil para C#)
    "ignorePaths": [
        "node_modules/",
        "dist/",
        "build/",
        "bin/", // Ignorar carpetas de compilación de .NET
        "obj/", // Ignorar carpetas de compilación de .NET
        "*.lock",
        "*.log",
        "*.dll"
    ],
    // Ignorar patrones, ej. códigos hexadecimales o GUIDs (aunque ya es bueno en esto)
    "ignoreRegExpList": [
        "/0x[0-9a-fA-F]+/i"
    ]
}
